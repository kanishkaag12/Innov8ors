PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/synapescrow
JWT_SECRET=replace_with_a_strong_secret

# Existing AI keys used in other backend features
GEMINI_API_KEY=your_existing_key
GROQ_API_KEY=your_existing_key

# SynapBot Gemma 4 settings
# Put your provider API key here (required)
GEMMA4_API_KEY=

# Put your provider OpenAI-compatible base URL here if required by provider (optional)
# Example: https://api.openrouter.ai/v1
GEMMA4_API_BASE_URL=

# Put your Gemma 4 model identifier here
# Example values depend on provider catalog; keep Gemma 4 family model only.
GEMMA4_MODEL=gemma-4
