# Environment Configuration Template for ML Ranking System

# ========== DATABASE CONFIGURATION ==========
# Use either individual fields or a full DATABASE_URL. If DATABASE_URL is set, it takes precedence.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synapescrow_ml
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:password@localhost:5432/synapescrow_ml?sslmode=prefer

# =========== ML MODEL PATHS ===========
ML_MODEL_PATH=./ranking_model.pkl
ML_SCALER_PATH=./scaler.pkl
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ========== API SERVER ==========
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# ========== ENABLE FEATURES ==========
ENABLE_BACKGROUND_RETRAINING=true
ENABLE_MODEL_CACHING=true
ENABLE_FEATURE_CACHING=false

# ========== FEATURE ENGINEERING ==========
BATCH_SIZE_EMBEDDINGS=32
NUM_EMBEDDING_PROCESSES=4

# ========== DATA GENERATION ==========
NUM_SYNTHETIC_FREELANCERS=1000
NUM_SYNTHETIC_JOBS=500
PROPOSALS_PER_JOB=8

# ========== MONITORING ==========
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# ========== CORS SETTINGS ==========
ALLOWED_ORIGINS=*
ALLOW_CREDENTIALS=true

# ========== SECURITY ==========
SECRET_KEY=your_jwt_secret_key_here
API_KEY=your_api_key_here

# ========== DEBUG ==========
DEBUG=false
